{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the e-commerce application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile photo."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The role of the user."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Dish": {
      "title": "Dish",
      "description": "Represents a food item/product in the menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number", "description": "Original price before discount, used for Flash Deals" },
        "freeDelivery": { "type": "boolean", "description": "Whether the product has free delivery" },
        "images": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of image URLs or base64 strings"
        },
        "promoCode": { "type": "string" },
        "discountAmount": { "type": "number" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "prepTime": { "type": "string" },
        "calories": { "type": "string" },
        "points": { "type": "number", "description": "Points earned when purchasing this item" }
      },
      "required": ["name", "description", "price", "images"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string", "description": "Font Awesome class name, e.g., 'fa-solid fa-burger'" }
      },
      "required": ["name", "icon"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "The items included in the order."
        },
        "subtotal": {
          "type": "number",
          "description": "The subtotal of the order."
        },
        "deliveryFee": {
          "type": "number",
          "description": "The delivery fee."
        },
        "tax": {
          "type": "number",
          "description": "The tax amount."
        },
        "total": {
          "type": "number",
          "description": "The total amount of the order."
        },
        "status": {
          "type": "string",
          "description": "The status of the order (e.g., 'placed', 'preparing', 'out_for_delivery', 'delivered')."
        },
        "shippingAddress": {
          "type": "string",
          "description": "The shipping address for the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the order was created."
        }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/dishes/{dishId}": {
      "schema": {
        "$ref": "#/entities/Dish"
      },
      "description": "Stores food items/products."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores orders placed by users."
    },
    "/categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/Category"
      },
      "description": "Stores product categories."
    }
  }
}
